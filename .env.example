# Intelligent CX Triage Agent Environment Configuration

# Server Port
PORT=3001

# Anthropic API credentials
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional model choice (defaults to claude-3-5-sonnet-20241022)
# Common options: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Zendesk API Credentials (Optional - backend falls back to local DB if not provided)
# Note: Use your actual Zendesk subdomain (e.g. if URL is mycompany.zendesk.com, subdomain is 'mycompany')
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
# Generate a token in Zendesk Admin Center > Apps and Integrations > APIs > Zendesk API
ZENDESK_API_TOKEN=

# Database Connection (Postgres container for local dev)
DATABASE_URL="postgresql://postgres:secret_password@localhost:5432/triage_db?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret_password
POSTGRES_DB=triage_db

# Honeycomb Observability Traces API Key (Optional)
HONEYCOMB_API_KEY=""